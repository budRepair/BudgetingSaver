                  "SqlStatement": "INSERT \r\nINTO \"INP_予算_販管費_一般管理費\" (\"年度\", \"組織コード\", \"科目コード\", \"バージョン\", \"予算部門コード\")\r\n SELECT\r\n    @pmt1 AS \"年度\"\r\n    , @pmt3 AS \"組織コード\"\r\n    , \"科目コード\"\r\n    , @pmt4 AS \"バージョン\"\r\n    , @pmt5 \r\nFROM\r\n    \"MST_科目\" \r\nWHERE\r\n    \"区分\" = '2' \r\n    AND \"会社コード\" = @pmt2;",
