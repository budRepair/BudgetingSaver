                      "SqlStatement": "DELETE \r\nFROM\r\n    \"INP_予算_配賦後\" \r\nWHERE\r\n    \"年度\" = @pmt1 \r\n    AND ( \r\n        (@pmt2 IS NOT NULL AND \"組織コード\" = @pmt2) \r\n        OR (@pmt2 IS NULL AND 1 = 1)\r\n    ) \r\n    AND EXISTS ( \r\n        SELECT\r\n            'x' \r\n        FROM\r\n            \"WK_共通_取込用\" \r\n        WHERE\r\n            \"INP_予算_配賦後\".\"組織コード\" = \"WK_共通_取込用\".\"組織コード\" \r\n            AND \"INP_予算_配賦後\".\"科目コード\" = \"WK_共通_取込用\".\"科目コード\" \r\n            AND \"INP_予算_配賦後\".\"月\" = \"WK_共通_取込用\".\"月\"\r\n    ); \r\n\r\nINSERT \r\nINTO \"INP_予算_配賦後\" ( \r\n    \"年度\"\r\n    , \"月\"\r\n    , \"組織コード\"\r\n    , \"組織名\"\r\n    , \"科目コード\"\r\n    , \"科目名\"\r\n    , \"金額\"\r\n    , \"バージョン\"\r\n) \r\nSELECT\r\n    \"年度\"\r\n    , \"月\"\r\n    , \"組織コード\"\r\n    , \"組織名\"\r\n    , \"科目コード\"\r\n    , \"科目名\"\r\n    , \"金額\"\r\n    , \"バージョン\" \r\nFROM\r\n    \"WK_共通_取込用\" \r\nWHERE\r\n    \"年度\" = @pmt1 \r\n    AND ( \r\n        (@pmt2 IS NOT NULL AND \"組織コード\" = @pmt2) \r\n        OR (@pmt2 IS NULL AND 1 = 1)\r\n    ) \r\n    AND \"画面ID\" = @pmt3;",
                      "ReturnsName": "return0",
