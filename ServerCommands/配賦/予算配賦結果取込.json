                "@msg4": {
                  "Item1": {
                    "$type": "Forguncy.Model.FormulaReferObject, ServerDesignerCommon",
                    "SerializeProperty": "=_msg4"
                  },
                  "Item2": 16
                }
              },
              "SqlStatement": "DELETE \r\nFROM\r\n    \"TRN_エラー一覧\" \r\nWHERE\r\n    \"画面ID\" = @pmt3; \r\n\r\nINSERT \r\nINTO \"TRN_エラー一覧\" ( \r\n    \"年度\"\r\n    , \"月\"\r\n    , \"画面ID\"\r\n    , \"画面名称\"\r\n    , \"組織コード\"\r\n    , \"エラーコード\"\r\n    , \"エラー内容\"\r\n) \r\nSELECT\r\n    wk_act.\"年度\"\r\n    , wk_act.\"月\"\r\n    , @pmt3 AS \"画面ID\"\r\n    , @pmt4 AS \"画面名称\"\r\n    , wk_act.\"組織コード\"\r\n    , CASE \r\n        WHEN m_acc.\"科目コード\" IS NULL \r\n            THEN wk_act.\"科目コード\" \r\n        ELSE NULL \r\n        END AS \"エラーコード\"\r\n    , CASE \r\n        WHEN wk_act.\"年度\" = @pmt1 \r\n            THEN CASE \r\n            WHEN m_mon.\"月コード\" IS NOT NULL \r\n                THEN CASE \r\n                WHEN m_ent.\"組織コード\" IS NULL \r\n                    THEN @msg3 \r\n                WHEN m_acc.\"科目コード\" IS NULL \r\n                    THEN @msg4 \r\n                END \r\n            ELSE @msg2 \r\n            END \r\n        ELSE @msg1 \r\n        END AS \"エラー内容\" \r\nFROM\r\n    \"WK_共通_取込用\" wk_act \r\n    LEFT JOIN \"MST_月\" m_mon \r\n        ON wk_act.\"月\" = m_mon.\"月コード\" \r\n    LEFT JOIN \"MST_組織\" m_ent \r\n        ON wk_act.\"組織コード\" = m_ent.\"組織コード\" \r\n    LEFT JOIN \"MST_科目\" m_acc \r\n        ON wk_act.\"科目コード\" = m_acc.\"科目コード\" \r\nWHERE\r\n    ( \r\n        wk_act.\"年度\" IS NULL \r\n        OR wk_act.\"月\" IS NULL \r\n        OR m_ent.\"組織コード\" IS NULL \r\n        OR m_acc.\"科目コード\" IS NULL \r\n        OR wk_act.\"年度\" <> @pmt1\r\n    ) \r\n    AND wk_act.\"画面ID\" = @pmt3;",
              "ReturnsName": "return0",
              "ID": "5823064bfd5d4366a8ab7f1d4485eed2",
              "Comments": ""
            },
