                      "SqlStatement": "DELETE \r\nFROM\r\n    \"INP_実績_損益計算書\" \r\nWHERE\r\n    \"年度\" = @pmt1 \r\n    AND \"月\" = @pmt2 \r\n    AND \"組織コード\" = @pmt3; \r\n\r\nINSERT \r\nINTO \"INP_実績_損益計算書\" (\"年度\", \"月\", \"組織コード\", \"組織名\", \"科目コード\", \"科目名\", \"金額\") \r\nSELECT\r\n    \"年度\"\r\n    , \"月\"\r\n    , \"組織コード\"\r\n    , \"組織名\"\r\n    , \"科目コード\"\r\n    , \"科目名\"\r\n    , \"金額\" \r\nFROM\r\n    \"WK_共通_取込用\" \r\nWHERE\r\n    \"年度\" = @pmt1 \r\n    AND \"月\" = @pmt2 \r\n    AND \"組織コード\" = @pmt3;",
