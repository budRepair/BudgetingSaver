                      "SqlStatement": "DELETE \r\nFROM\r\n    \"INP_実績_売上\" \r\nWHERE\r\n    \"年度\" = @pmt1 \r\n    AND \"月\" = @pmt2 \r\n    AND \"組織コード\" = @pmt3; \r\n\r\nINSERT \r\nINTO \"INP_実績_売上\" ( \r\n    \"年度\"\r\n    , \"月\"\r\n    , \"組織コード\"\r\n    , \"組織名\"\r\n    , \"科目コード\"\r\n    , \"科目名\"\r\n    , \"親属性コード\"\r\n    , \"親属性名称\"\r\n    , \"属性コード\"\r\n    , \"属性名称\"\r\n    , \"金額\"\r\n) \r\nSELECT\r\n    wk_act.\"年度\"\r\n    , wk_act.\"月\"\r\n    , wk_act.\"組織コード\"\r\n    , wk_act.\"組織名\"\r\n    , wk_act.\"科目コード\"\r\n    , wk_act.\"科目名\"\r\n    , m_prd.\"親属性コード\"\r\n    , m_prd.\"親属性名称\"\r\n    , m_prd.\"属性コード\"\r\n    , m_prd.\"属性名称\"\r\n    , wk_act.\"金額\" \r\nFROM\r\n    \"WK_実績_売上\" wk_act \r\n    LEFT JOIN \"MST_属性\" m_prd \r\n        ON wk_act.\"属性コード\" = m_prd.\"属性コード\" \r\nWHERE\r\n    wk_act.\"年度\" = @pmt1 \r\n    AND wk_act.\"月\" = @pmt2 \r\n    AND wk_act.\"組織コード\" = @pmt3;",
