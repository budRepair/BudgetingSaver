                    "$type": "Forguncy.Model.FormulaReferObject, ServerDesignerCommon",
                    "SerializeProperty": "=_msg4"
                  },
                  "Item2": 16
                }
              },
              "SqlStatement": "DELETE \r\nFROM\r\n    \"TRN_エラー一覧\" \r\nWHERE\r\n    \"画面ID\" = @pmt4; \r\n\r\nINSERT \r\nINTO \"TRN_エラー一覧\" ( \r\n    \"年度\"\r\n    , \"月\"\r\n    , \"画面ID\"\r\n    , \"画面名称\"\r\n    , \"組織コード\"\r\n    , \"エラーコード\"\r\n    , \"エラー内容\"\r\n) \r\nSELECT\r\n    wk_act.\"年度\"\r\n    , wk_act.\"月\"\r\n    , @pmt4 AS \"画面ID\"\r\n    , @pmt5 AS \"画面名称\"\r\n    , wk_act.\"組織コード\"\r\n    , CASE \r\n        WHEN m_prd.\"属性コード\" IS NULL \r\n            THEN wk_act.\"属性コード\" \r\n        ELSE NULL \r\n        END AS \"エラーコード\"\r\n    , CASE \r\n        WHEN wk_act.\"年度\" = @pmt1 \r\n            THEN CASE \r\n            WHEN wk_act.\"月\" = @pmt2 \r\n                THEN CASE \r\n                WHEN m_ent.\"組織コード\" IS NULL \r\n                    THEN @msg3 \r\n                WHEN m_prd.\"属性コード\" IS NULL \r\n                    THEN @msg4 \r\n                END \r\n            ELSE @msg2 \r\n            END \r\n        ELSE @msg1 \r\n        END AS \"エラー内容\" \r\nFROM\r\n    \"WK_実績_売上\" wk_act \r\n    LEFT JOIN \"MST_組織\" m_ent \r\n        ON wk_act.\"組織コード\" = m_ent.\"組織コード\" \r\n    LEFT JOIN \"MST_属性\" m_prd \r\n        ON wk_act.\"属性コード\" = m_prd.\"属性コード\" \r\nWHERE\r\n    wk_act.\"年度\" IS NULL \r\n    OR wk_act.\"月\" IS NULL \r\n    OR m_ent.\"組織コード\" IS NULL \r\n    OR m_prd.\"属性コード\" IS NULL \r\n    OR wk_act.\"年度\" <> @pmt1 \r\n    OR wk_act.\"月\" <> @pmt2;",
              "ReturnsName": "return0",
              "ID": "f3c7ab552fa84fcf9674c062354af578",
              "Comments": ""
            },
