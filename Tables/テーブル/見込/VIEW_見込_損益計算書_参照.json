  "BuiltInViewInfo": {
    "ViewName": "VIEW_見込_損益計算書_参照",
    "SourceViewName": "fgc4b1b69b38ca646609e80c812073",
    "CreateViewSql": "SELECT\r\n\"年度\",\r\n見込.\"組織コード\",\r\n見込.\"科目コード\",\r\n\"連結科目コード\",\r\n\"_4月\",\r\n\"_5月\",\r\n\"_6月\",\r\n\"_7月\",\r\n\"_8月\",\r\n\"_9月\",\r\n\"_10月\",\r\n\"_11月\",\r\n\"_12月\",\r\n\"_1月\",\r\n\"_2月\",\r\n\"_3月\",\r\n\"バージョン\",\r\n組織.\"会社コード\"\r\nFROM \"INP_見込_損益計算書\" 見込\r\nLEFT JOIN \"MST_組織\" 組織\r\nON 見込.\"組織コード\" = 組織.\"組織コード\"\r\nLEFT JOIN \"MST_科目\" 科目\r\nON 見込.\"科目コード\" = 科目.\"科目コード\"\r\nAND 組織.\"会社コード\" =科目.\"会社コード\""
  },
