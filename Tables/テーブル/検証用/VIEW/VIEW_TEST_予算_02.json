  "BuiltInViewInfo": {
    "ViewName": "VIEW_TEST_予算_02",
    "SourceViewName": "fgcc33432b95079454ebd71568f56e",
    "CreateViewSql": "SELECT\r\n tbl.\"年度\",\r\n mst.\"大項目コード\",\r\n SUM(tbl.\"_4月\") AS \"4月\",\r\n SUM(tbl.\"_5月\") AS \"5月\",\r\n SUM(tbl.\"_6月\") AS \"6月\",\r\n SUM(tbl.\"_7月\") AS \"7月\",\r\n SUM(tbl.\"_8月\") AS \"8月\",\r\n SUM(tbl.\"_9月\") AS \"9月\",\r\n SUM(tbl.\"_10月\") AS \"10月\",\r\n SUM(tbl.\"_11月\") AS \"11月\",\r\n SUM(tbl.\"_12月\") AS \"12月\",\r\n SUM(tbl.\"_1月\") AS \"1月\",\r\n SUM(tbl.\"_2月\") AS \"2月\",\r\n SUM(tbl.\"_3月\") AS \"3月\",\r\n tbl.\"バージョン\"\r\nFROM \"INP_予算_損益計算書\" tbl\r\n\r\nINNER JOIN \"TEST_科目マスタ\" mst\r\n ON mst.\"科目コード\" = tbl.\"科目コード\"\r\n\r\nGROUP BY\r\n tbl.\"年度\",\r\n mst.\"大項目コード\",\r\n tbl.\"バージョン\""
  },
