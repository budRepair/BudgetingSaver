  "BuiltInViewInfo": {
    "ViewName": "VIEW_TEST_予算",
    "SourceViewName": "fgc4134a369037e45e0849c1b81e94",
    "CreateViewSql": "SELECT\r\n tbl.\"年度\",\r\n tbl.\"組織コード\",\r\n tbl.\"科目コード\",\r\n mst.\"月コード\" AS \"月\",\r\n CASE mst.\"月コード\"\r\n   WHEN '04' THEN tbl.\"_4月\"\r\n   WHEN '05' THEN tbl.\"_5月\"\r\n   WHEN '06' THEN tbl.\"_6月\"\r\n   WHEN '07' THEN tbl.\"_7月\"\r\n   WHEN '08' THEN tbl.\"_8月\"\r\n   WHEN '09' THEN tbl.\"_9月\"\r\n   WHEN '10' THEN tbl.\"_10月\"\r\n   WHEN '11' THEN tbl.\"_11月\"\r\n   WHEN '12' THEN tbl.\"_12月\"\r\n   WHEN '01' THEN tbl.\"_1月\"\r\n   WHEN '02' THEN tbl.\"_2月\"\r\n   WHEN '03' THEN tbl.\"_3月\"\r\n END  AS \"金額\",\r\n \"バージョン\"\r\nFROM \"INP_予算_損益計算書\" tbl\r\n\r\nLEFT OUTER JOIN \"MST_年度_検証用\" mst\r\nON  tbl.\"年度\" = mst.\"年度\""
  },
