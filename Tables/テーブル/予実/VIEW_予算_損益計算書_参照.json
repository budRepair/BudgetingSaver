  "BuiltInViewInfo": {
    "ViewName": "VIEW_予算_損益計算書_参照",
    "SourceViewName": "fgca268e8bab15a48cab206449c695",
    "CreateViewSql": "SELECT\r\n\"年度\",\r\n損益.\"組織コード\",\r\n損益.\"科目コード\",\r\n\"連結科目コード\",\r\n\"4月\",\r\n\"5月\",\r\n\"6月\",\r\n\"7月\",\r\n\"8月\",\r\n\"9月\",\r\n\"10月\",\r\n\"11月\",\r\n\"12月\",\r\n\"1月\",\r\n\"2月\",\r\n\"3月\",\r\n\"バージョン\",\r\n組織.\"会社コード\"\r\nFROM \"VIEW_予算_損益計算書\" 損益\r\nLEFT JOIN \"MST_組織\" 組織\r\nON 損益.\"組織コード\" = 組織.\"組織コード\"\r\nLEFT JOIN \"MST_科目\" 科目\r\nON 損益.\"科目コード\" = 科目.\"科目コード\"\r\nAND 組織.\"会社コード\" =科目.\"会社コード\""
  },
