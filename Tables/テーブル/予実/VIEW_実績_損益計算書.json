  "BuiltInViewInfo": {
    "ViewName": "VIEW_実績_損益計算書",
    "SourceViewName": "fgcfba6388edc3d4c909feb1fad8ad",
    "CreateViewSql": "SELECT\r\n \"年度\",\r\n \"組織コード\",\r\n \"科目コード\",\r\n SUM(CASE WHEN \"月\" = \"04\" THEN \"金額\" END) AS \"4月\",\r\n SUM(CASE WHEN \"月\" = \"05\" THEN \"金額\" END) AS \"5月\",\r\n SUM(CASE WHEN \"月\" = \"06\" THEN \"金額\" END) AS \"6月\",\r\n SUM(CASE WHEN \"月\" = \"07\" THEN \"金額\" END) AS \"7月\",\r\n SUM(CASE WHEN \"月\" = \"08\" THEN \"金額\" END) AS \"8月\",\r\n SUM(CASE WHEN \"月\" = \"09\" THEN \"金額\" END) AS \"9月\",\r\n SUM(CASE WHEN \"月\" = \"10\" THEN \"金額\" END) AS \"10月\",\r\n SUM(CASE WHEN \"月\" = \"11\" THEN \"金額\" END) AS \"11月\",\r\n SUM(CASE WHEN \"月\" = \"12\" THEN \"金額\" END) AS \"12月\",\r\n SUM(CASE WHEN \"月\" = \"01\" THEN \"金額\" END) AS \"1月\",\r\n SUM(CASE WHEN \"月\" = \"02\" THEN \"金額\" END) AS \"2月\",\r\n SUM(CASE WHEN \"月\" = \"03\" THEN \"金額\" END) AS \"3月\"\r\nFROM (\r\n  SELECT\r\n   \"年度\",\r\n   \"組織コード\",\r\n   \"科目コード\",\r\n   \"月\",\r\n   \"金額\"\r\n  FROM \"INP_実績_配賦後\"\r\n  UNION ALL\r\n  SELECT\r\n   \"年度\",\r\n   \"組織コード\",\r\n   \"科目コード\",\r\n   \"月\",\r\n   \"金額\"\r\n  FROM \"INP_実績_売上\"\r\n) act\r\nGROUP BY\r\n \"年度\",\r\n \"組織コード\",\r\n \"科目コード\""
  },
