    "CreateViewSql": "SELECT\r\n \"年度\",\r\n \"組織コード\",\r\n \"科目コード\",\r\n SUM(\"_4月\") AS \"4月\",\r\n SUM(\"_5月\") AS \"5月\",\r\n SUM(\"_6月\") AS \"6月\",\r\n SUM(\"_7月\") AS \"7月\",\r\n SUM(\"_8月\") AS \"8月\",\r\n SUM(\"_9月\") AS \"9月\",\r\n SUM(\"_10月\") AS \"10月\",\r\n SUM(\"_11月\") AS \"11月\",\r\n SUM(\"_12月\") AS \"12月\",\r\n SUM(\"_1月\") AS \"1月\",\r\n SUM(\"_2月\") AS \"2月\",\r\n SUM(\"_3月\") AS \"3月\",\r\n \"バージョン\"\r\nFROM \"INP_予算_売上\"\r\nGROUP BY\r\n \"年度\",\r\n \"組織コード\",\r\n \"科目コード\",\r\n \"バージョン\"\r\nUNION ALL\r\nSELECT\r\n \"年度\",\r\n \"組織コード\",\r\n '52517' AS \"科目コード\",\r\n SUM(\"_4月\") AS \"4月\",\r\n SUM(\"_5月\") AS \"5月\",\r\n SUM(\"_6月\") AS \"6月\",\r\n SUM(\"_7月\") AS \"7月\",\r\n SUM(\"_8月\") AS \"8月\",\r\n SUM(\"_9月\") AS \"9月\",\r\n SUM(\"_10月\") AS \"10月\",\r\n SUM(\"_11月\") AS \"11月\",\r\n SUM(\"_12月\") AS \"12月\",\r\n SUM(\"_1月\") AS \"1月\",\r\n SUM(\"_2月\") AS \"2月\",\r\n SUM(\"_3月\") AS \"3月\",\r\n \"バージョン\"\r\nFROM \"INP_予算_売上原価\"\r\nGROUP BY\r\n \"年度\",\r\n \"組織コード\",\r\n \"科目コード\",\r\n \"バージョン\"\r\nUNION ALL\r\nSELECT\r\n \"年度\",\r\n \"組織コード\",\r\n \"科目コード\",\r\n  SUM(CASE WHEN \"月\" = \"04\" THEN \"金額\" END) AS \"4月\",\r\n  SUM(CASE WHEN \"月\" = \"05\" THEN \"金額\" END) AS \"5月\",\r\n  SUM(CASE WHEN \"月\" = \"06\" THEN \"金額\" END) AS \"6月\",\r\n  SUM(CASE WHEN \"月\" = \"07\" THEN \"金額\" END) AS \"7月\",\r\n  SUM(CASE WHEN \"月\" = \"08\" THEN \"金額\" END) AS \"8月\",\r\n  SUM(CASE WHEN \"月\" = \"09\" THEN \"金額\" END) AS \"9月\",\r\n  SUM(CASE WHEN \"月\" = \"10\" THEN \"金額\" END) AS \"10月\",\r\n  SUM(CASE WHEN \"月\" = \"11\" THEN \"金額\" END) AS \"11月\",\r\n  SUM(CASE WHEN \"月\" = \"12\" THEN \"金額\" END) AS \"12月\",\r\n  SUM(CASE WHEN \"月\" = \"01\" THEN \"金額\" END) AS \"1月\",\r\n  SUM(CASE WHEN \"月\" = \"02\" THEN \"金額\" END) AS \"2月\",\r\n  SUM(CASE WHEN \"月\" = \"03\" THEN \"金額\" END) AS \"3月\",\r\n \"バージョン\"\r\nFROM \"INP_予算_配賦後\"\r\nGROUP BY\r\n \"年度\",\r\n \"組織コード\",\r\n \"科目コード\",\r\n \"バージョン\""
